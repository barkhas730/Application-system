# .env.example — Энэ файлыг .env болгон хуулж, утгуудыг өөрчилнө.
# АНХААРУУЛГА: .env файлыг git commit хийж болохгүй!

# Нууц түлхүүр — production дээр урт санамсаргүй тэмдэгт ашиглана
SECRET_KEY=your-very-long-random-secret-key-here

# Debug горим — production дээр False байх ёстой
DEBUG=True

# Зөвшөөрөгдсөн хостууд (production дээр домайн нэрийг оруулна)
ALLOWED_HOSTS=*
